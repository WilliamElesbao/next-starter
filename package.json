{
  "name": "next-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun next dev",
    "build": "bun run db:generate && next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage:open": "open coverage/lcov-report/index.html",
    "test:coverage:watch": "vitest --coverage",
    "test:ui": "vitest --ui",
    "lint": "biome check .",
    "lint:fix": "biome check --fix --unsafe .",
    "ci": "biome ci .",
    "format": "bun biome check . --write",
    "lint:watch": "bunx onchange . -- biome check --write --no-errors-on-unmatched {{changed}}",
    "locale-check": "bun run src/scripts/validate-i18n.ts",
    "locale-unused": "bun run src/scripts/check-unused-i18n-keys.ts",
    "prepare": "husky",
    "better-auth:generate": "bunx --bun @better-auth/cli generate --config src/lib/better-auth/auth.ts",
    "db:generate": "bunx --bun prisma generate",
    "db:migrate": "bunx --bun prisma migrate dev",
    "db:seed": "bunx --bun prisma db seed",
    "db:studio": "bunx --bun prisma studio"
  },
  "dependencies": {
    "@better-auth/stripe": "1.6.23",
    "@hookform/resolvers": "5.2.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.8",
    "@t3-oss/env-nextjs": "0.13.11",
    "@tabler/icons-react": "3.40.0",
    "@tanstack/react-query": "5.100.10",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "17.4.2",
    "lucide-react": "1.16.0",
    "next": "16.2.10",
    "next-intl": "4.12.0",
    "next-themes": "0.4.6",
    "pg": "8.20.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "6.1.5",
    "react-hook-form": "7.72.0",
    "resend": "6.12.3",
    "shadcn": "4.7.0",
    "sonner": "2.0.7",
    "stripe": "22.0.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@faker-js/faker": "10.4.0",
    "@tailwindcss/postcss": "4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "20",
    "@types/pg": "8.20.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-istanbul": "4.1.8",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "bun-types": "1.3.14",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "prisma": "7.8.0",
    "tailwindcss": "4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
